{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard",
        "model": "openrouter/anthropic/claude-haiku-4-5",
        "notifyUser": false,
        "keepRecentTokens": 6000,
        "maxHistoryShare": 0.45,
        "recentTurnsPreserve": 2,
        "timeoutSeconds": 120
      },
      "maxConcurrent": 4,
      "model": {
        "primary": "ollama/minimax-m2.5:cloud",
        "fallbacks": [
          "openrouter/anthropic/claude-haiku-4-5",
          "ollama/qwen2.5:7b"
        ]
      },
      "models": {
        "openrouter/anthropic/claude-haiku-4-5": { "alias": "haiku" },
        "openrouter/anthropic/claude-sonnet-4-5": { "alias": "sonnet" },
        "openrouter/auto": { "alias": "OpenRouter" }
      },
      "subagents": { "maxConcurrent": 8 },
      "timeoutSeconds": 600,
      "workspace": "/path/to/workspace"
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  },
  "channels": {
    "telegram": {
      "allowFrom": ["YOUR_TELEGRAM_ID"],
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "dmPolicy": "allowlist",
      "enabled": true,
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "command": "/path/to/qmd",
      "searchMode": "search",
      "includeDefaultMemory": true,
      "limits": {
        "maxResults": 3,
        "maxSnippetChars": 350,
        "maxInjectedChars": 1000
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "auth": "api-key",
        "models": [
          {
            "id": "minimax-m2.5:cloud",
            "name": "minimax-m2.5:cloud",
            "contextWindow": 204800,
            "maxTokens": 128000
          },
          {
            "id": "qwen2.5:7b",
            "name": "qwen2.5:7b",
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "models": [
          {
            "id": "anthropic/claude-haiku-4-5",
            "name": "Claude Haiku 4.5",
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "anthropic/claude-sonnet-4-5",
            "name": "Claude Sonnet 4.5",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "plugins": {
    "allow": ["ollama", "openclaw-web-search", "openrouter", "telegram"],
    "entries": {
      "ollama": { "enabled": true },
      "openclaw-web-search": { "enabled": true },
      "openrouter": { "enabled": true },
      "telegram": { "enabled": true }
    }
  }
}
