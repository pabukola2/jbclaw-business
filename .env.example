# Business Agent - Required Credentials

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Telegram Bot Token (if using Telegram)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg

# Discord Bot Token (if using Discord)
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Slack Bot Token (if using Slack)
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Your Business Name
BUSINESS_NAME="My AI Agent"

# Optional: Support Email
SUPPORT_EMAIL=support@example.com
